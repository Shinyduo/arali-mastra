# === Required: Database & Auth ===
DATABASE_URL=                               # Shared Arali DB (tools query this)
JWT_SECRET=                                 # Must match arali-main

# === Mastra Storage (optional, separate DB) ===
# MASTRA_DATABASE_URL=                      # Separate DB for Mastra tables (memory, threads, etc.)
                                            # If not set, falls back to DATABASE_URL

# === LLM Provider (pick one) ===
AI_PROVIDER=google                          # google | anthropic | openai
AI_MODEL=gemini-2.5-flash                   # override model for any provider

# Provider API keys — only the one matching AI_PROVIDER is needed
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                             # also used for embeddings (semantic search)

# === Optional ===
PORT=4111
NODE_ENV=development
